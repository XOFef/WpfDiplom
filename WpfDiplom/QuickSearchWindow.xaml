<Window x:Class="WpfDiplom.QuickSearchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Быстрый поиск | Банк «Стандарт»" Height="500" Width="900"
        WindowStartupLocation="CenterScreen"
        MinHeight="400" MinWidth="700"
        Background="#F0F2F5">
    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#1E3A5F"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#D0D5DD"/>
        <SolidColorBrush x:Key="ButtonBrush" Color="#2C5282"/>
        <SolidColorBrush x:Key="DeleteBrush" Color="#C0392B"/>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}"
                CornerRadius="4" Padding="12" Margin="0,0,0,8">
            <Grid>
                <TextBlock Text="Быстрый поиск клиентов" Foreground="White"
                           FontSize="17" FontWeight="Bold" VerticalAlignment="Center"/>
                <Button Content="Закрыть" Width="80" Height="28"
                        Background="#95A5A6" Foreground="White" BorderThickness="0"
                        FontSize="13" HorizontalAlignment="Right"
                        Click="BtnClose_Click"/>
            </Grid>
        </Border>

        <!-- Строка поиска -->
        <Border Grid.Row="1" Background="White" BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="SearchQuery" Grid.Column="0" Height="30" FontSize="14"
                         VerticalContentAlignment="Center" Padding="6,4"
                         BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"/>
                <Button Content="🔍 Найти" Grid.Column="1" Width="80" Height="30" Margin="8,0,0,0"
                        Background="{StaticResource ButtonBrush}" Foreground="White"
                        BorderThickness="0" FontSize="13" Click="BtnSearch_Click"/>
            </Grid>
        </Border>

        <!-- Таблица результатов -->
        <DataGrid Grid.Row="2" x:Name="SearchResultsGrid" IsReadOnly="True"
                  AutoGenerateColumns="False" SelectionMode="Single"
                  SelectionUnit="FullRow"
                  BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="{StaticResource BorderBrush}"
                  RowHeaderWidth="0" ColumnHeaderHeight="28" RowHeight="26"
                  FontSize="13" Background="White" Margin="0,0,0,8">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Width="60" Binding="{Binding Id}"/>
                <DataGridTextColumn Header="Тип" Width="80" Binding="{Binding Type}"/>
                <DataGridTextColumn Header="ФИО / Наименование" Width="200" Binding="{Binding FullName}"/>
                <DataGridTextColumn Header="ИНН / Паспорт" Width="130" Binding="{Binding InnPassport}"/>
                <DataGridTextColumn Header="Статус" Width="100" Binding="{Binding Status}"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Кнопки действий с выделенной строкой -->
        <Border Grid.Row="3" Background="White" BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1" CornerRadius="4" Padding="8">
            <StackPanel Orientation="Horizontal">
                <Button Content="👁 Просмотр карточки" Width="150" Height="28"
                        Background="{StaticResource ButtonBrush}" Foreground="White"
                        BorderThickness="0" FontSize="13" Margin="0,0,8,0"
                        Click="BtnViewCard_Click"/>
                <Button Content="✏ Редактировать" Width="120" Height="28"
                        Background="{StaticResource ButtonBrush}" Foreground="White"
                        BorderThickness="0" FontSize="13" Margin="0,0,8,0"
                        Click="BtnEdit_Click"/>
                <Button Content="🗑 Удалить" Width="100" Height="28"
                        Background="{StaticResource DeleteBrush}" Foreground="White"
                        BorderThickness="0" FontSize="13" Click="BtnDelete_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>