<Window x:Class="WpfDiplom.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Авторизация" Height="540" Width="460"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Window.Resources>
        <!-- Кисти -->
        <SolidColorBrush x:Key="PrimaryBrush" Color="#1E3A5F"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#D4AF37"/>
        <SolidColorBrush x:Key="BackgroundBrush" Color="#F5F7FA"/>
        <SolidColorBrush x:Key="TextBrush" Color="#2C3E50"/>
        <SolidColorBrush x:Key="ErrorBrush" Color="#C0392B"/>
        <SolidColorBrush x:Key="PlaceholderBrush" Color="#95A5A6"/>

        <!-- Стиль TextBox с placeholder -->
        <Style TargetType="TextBox" x:Key="LoginTextBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <Grid>
                                <TextBlock x:Name="Placeholder" Text="Введите логин"
                                           Foreground="{StaticResource PlaceholderBrush}"
                                           FontSize="14" VerticalAlignment="Center"
                                           Margin="10,0,0,0"
                                           IsHitTestVisible="False"
                                           Visibility="Collapsed"/>
                                <ScrollViewer x:Name="PART_ContentHost" Margin="5,0"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="Placeholder" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Placeholder" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль PasswordBox с placeholder (управляется из кода) -->
        <Style TargetType="PasswordBox" x:Key="LoginPasswordBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <Grid>
                                <TextBlock x:Name="Placeholder" Text="Введите пароль"
                                           Foreground="{StaticResource PlaceholderBrush}"
                                           FontSize="14" VerticalAlignment="Center"
                                           Margin="10,0,0,0"
                                           IsHitTestVisible="False"
                                           Visibility="Collapsed"/>
                                <ScrollViewer x:Name="PART_ContentHost" Margin="5,0"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Кнопка входа -->
        <Style TargetType="Button" x:Key="LoginButton">
            <Setter Property="Height" Value="44"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#1E3A5F" Offset="0"/>
                        <GradientStop Color="#2C5282" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background">
                        <Setter.Value>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#2C5282" Offset="0"/>
                                <GradientStop Color="#3A6EA5" Offset="1"/>
                            </LinearGradientBrush>
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background">
                        <Setter.Value>
                            <SolidColorBrush Color="#16324A"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <!-- Основной Grid с фоном -->
    <Grid Background="{StaticResource BackgroundBrush}">
        <!-- Золотая полоса -->
        <Border Height="6" Background="{StaticResource AccentBrush}" VerticalAlignment="Top"/>

        <!-- Карточка входа -->
        <Border Width="350" Padding="30" Background="White"
                CornerRadius="8" VerticalAlignment="Center"
                BorderBrush="#E0E6ED" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="3" Opacity="0.15" Color="#1E3A5F"/>
            </Border.Effect>

            <StackPanel>
                

                    <!-- Название банка -->
                    <TextBlock Text="БАНК «СТАНДАРТ»"
                           FontSize="18" FontWeight="Bold"
                           Foreground="{StaticResource PrimaryBrush}"
                           HorizontalAlignment="Center" Margin="0,0,0,5"/>
                    <TextBlock Text="Система учёта клиентов"
                           FontSize="12" Foreground="#7F8C8D"
                           HorizontalAlignment="Center" Margin="0,0,0,25"/>

                    <!-- Логин -->
                    <TextBlock Text="Логин" FontSize="13" Foreground="{StaticResource TextBrush}"
                           Margin="0,0,0,4"/>
                    <TextBox x:Name="LoginTextBox" Style="{StaticResource LoginTextBox}"
                         Margin="0,0,0,15"/>

                    <!-- Пароль -->
                    <TextBlock Text="Пароль" FontSize="13" Foreground="{StaticResource TextBrush}"
                           Margin="0,0,0,4"/>
                    <PasswordBox x:Name="PasswordBoxCtrl" Style="{StaticResource LoginPasswordBox}"
                             Margin="0,0,0,20"/>

                    <!-- Кнопка Войти -->
                    <Button x:Name="LoginButton" Content="Войти"
                        Style="{StaticResource LoginButton}"
                        Click="LoginButton_Click"/>

                    <!-- Ошибка -->
                    <TextBlock x:Name="ErrorMessage" Text="Неверный логин или пароль"
                           Foreground="{StaticResource ErrorBrush}"
                           FontSize="12" HorizontalAlignment="Center"
                           Margin="0,10,0,0" Visibility="Collapsed"/>
            </StackPanel>
        </Border>

        <!-- Подвал -->
        <TextBlock Text="Версия 1.0.0.0 | © 2025 Банк «Стандарт»"
                   FontSize="10" Foreground="#95A5A6"
                   HorizontalAlignment="Center" VerticalAlignment="Bottom"
                   Margin="0,0,0,15"/>
    </Grid>
</Window>