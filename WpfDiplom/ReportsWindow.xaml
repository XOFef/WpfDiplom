<Window x:Class="WpfDiplom.ReportsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Отчёты | Банк «Стандарт»" Height="650" Width="1000"
        WindowStartupLocation="CenterScreen"
        MinHeight="550" MinWidth="800"
        Background="#F5F7FA">
    <Window.Resources>
        <!-- Цветовая гамма -->
        <SolidColorBrush x:Key="PrimaryBrush" Color="#1E3A5F"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#D4AF37"/>
        <SolidColorBrush x:Key="BackgroundBrush" Color="#F5F7FA"/>
        <SolidColorBrush x:Key="TextBrush" Color="#2C3E50"/>
        <SolidColorBrush x:Key="LightTextBrush" Color="#7F8C8D"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#E0E6ED"/>
        <SolidColorBrush x:Key="ButtonBrush" Color="#2C5282"/>
        <SolidColorBrush x:Key="ButtonHoverBrush" Color="#3A6EA5"/>

        <!-- Простая кнопка -->
        <Style TargetType="Button" x:Key="SimpleButton">
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource ButtonBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource ButtonHoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль выпадающего списка -->
        <Style TargetType="ComboBox" x:Key="ReportCombo">
            <Setter Property="Height" Value="30"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <!-- Стиль DatePicker -->
        <Style TargetType="DatePicker" x:Key="ReportDate">
            <Setter Property="Height" Value="30"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- Стиль карточки-секции -->
        <Style TargetType="Border" x:Key="SectionCard">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="6" ShadowDepth="2" Opacity="0.08" Color="#1E3A5F"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для DataGrid -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="ColumnHeaderHeight" Value="32"/>
            <Setter Property="RowHeight" Value="30"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="Transparent" BorderThickness="0">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <Border Grid.Row="0" CornerRadius="6" Margin="0,0,0,10" Height="52">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#1E3A5F" Offset="0"/>
                    <GradientStop Color="#2C5282" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid Margin="14,0">
                <TextBlock Text="Отчёты" 
                           Foreground="White" FontSize="18" FontWeight="Bold"
                           VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Закрыть" Style="{StaticResource SimpleButton}"
                            Background="#95A5A6" Click="BtnClose_Click">
                        <Button.Resources>
                            <SolidColorBrush x:Key="Background" Color="#95A5A6"/>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Основная область с прокруткой -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Выбор шаблона отчёта -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="📊 Шаблон отчёта" FontSize="15" FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,10"/>
                        <ComboBox x:Name="CmbReportTemplate" Style="{StaticResource ReportCombo}"
                                  Width="400" HorizontalAlignment="Left" SelectedIndex="0">
                            <ComboBoxItem Content="Реестр клиентов по менеджерам"/>
                            <ComboBoxItem Content="Прирост клиентской базы за период"/>
                            <ComboBoxItem Content="Клиенты с истекающими документами"/>
                            <ComboBoxItem Content="Распределение по типам/регионам"/>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <!-- Параметры отчёта -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="⚙️ Параметры" FontSize="15" FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,10"/>
                        <WrapPanel>
                            <!-- Период -->
                            <StackPanel Margin="0,0,20,10">
                                <TextBlock Text="Период с" FontSize="12" Foreground="{StaticResource LightTextBrush}" Margin="0,0,0,2"/>
                                <DatePicker x:Name="DtFrom" Style="{StaticResource ReportDate}" Width="150"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,20,10">
                                <TextBlock Text="по" FontSize="12" Foreground="{StaticResource LightTextBrush}" Margin="0,0,0,2"/>
                                <DatePicker x:Name="DtTo" Style="{StaticResource ReportDate}" Width="150"/>
                            </StackPanel>

                            <!-- Отделение -->
                            <StackPanel Margin="0,0,20,10">
                                <TextBlock Text="Отделение" FontSize="12" Foreground="{StaticResource LightTextBrush}" Margin="0,0,0,2"/>
                                <ComboBox x:Name="CmbBranch" Style="{StaticResource ReportCombo}" Width="160" SelectedIndex="0">
                                    <ComboBoxItem Content="Все"/>
                                    <ComboBoxItem Content="Центральное"/>
                                    <ComboBoxItem Content="Северное"/>
                                    <ComboBoxItem Content="Южное"/>
                                </ComboBox>
                            </StackPanel>

                            <!-- Менеджер -->
                            <StackPanel Margin="0,0,20,10">
                                <TextBlock Text="Менеджер" FontSize="12" Foreground="{StaticResource LightTextBrush}" Margin="0,0,0,2"/>
                                <ComboBox x:Name="CmbManager" Style="{StaticResource ReportCombo}" Width="180" SelectedIndex="0">
                                    <ComboBoxItem Content="Все"/>
                                    <ComboBoxItem Content="Петрова А. В."/>
                                    <ComboBoxItem Content="Смирнов К. Д."/>
                                </ComboBox>
                            </StackPanel>
                        </WrapPanel>

                        <!-- Кнопки действий -->
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Content="📋 Сформировать" Style="{StaticResource SimpleButton}"
                                    Click="BtnGenerate_Click" Width="140"/>
                            <Button Content="📥 Excel" Style="{StaticResource SimpleButton}"
                                    Click="BtnExportExcel_Click" Width="100"/>
                            <Button Content="📄 PDF" Style="{StaticResource SimpleButton}"
                                    Click="BtnExportPdf_Click" Width="100"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Результат отчёта -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="📋 Результат" FontSize="15" FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,10"/>
                        <DataGrid x:Name="ReportGrid" IsReadOnly="True" AutoGenerateColumns="False"
                                  MinHeight="200" MaxHeight="400"
                                  Margin="0,0,0,0">
                            <!-- Колонки будут добавляться динамически в зависимости от шаблона,
                                 здесь оставим пример -->
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Пример" Width="*" Binding="{Binding Sample}"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <TextBlock x:Name="TxtNoData" Text="Нет данных для отображения"
                                   FontSize="13" Foreground="{StaticResource LightTextBrush}"
                                   HorizontalAlignment="Center" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>