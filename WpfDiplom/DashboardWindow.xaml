<Window x:Class="WpfDiplom.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Рабочий стол | Банк «Стандарт»" Height="760" Width="1300"
        WindowStartupLocation="CenterScreen"
        MinHeight="760" MinWidth="1220">
    <Window.Resources>
        <!-- Цветовая схема -->
        <SolidColorBrush x:Key="PrimaryBrush" Color="#1E3A5F"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#D4AF37"/>
        <SolidColorBrush x:Key="BackgroundBrush" Color="#F5F7FA"/>
        <SolidColorBrush x:Key="TextBrush" Color="#2C3E50"/>
        <SolidColorBrush x:Key="LightTextBrush" Color="#7F8C8D"/>
        <SolidColorBrush x:Key="WhiteBrush" Color="White"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#E0E6ED"/>

        <!-- Стиль кнопок бокового меню (отступ слева увеличен до 40) -->
        <Style TargetType="Button" x:Key="MenuButton">
            <Setter Property="Height" Value="45"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="40,0,0,0"/>
            <!-- Увеличено до 40 -->
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Left"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2C5282"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для карточек дашборда -->
        <Style TargetType="Border" x:Key="DashboardCard">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.1" Color="#1E3A5F"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль кнопок быстрых действий -->
        <Style TargetType="Button" x:Key="ActionButton">
            <Setter Property="Height" Value="42"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#1E3A5F" Offset="0"/>
                        <GradientStop Color="#2C5282" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="30,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background">
                        <Setter.Value>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#2C5282" Offset="0"/>
                                <GradientStop Color="#3A6EA5" Offset="1"/>
                            </LinearGradientBrush>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <!-- Основной макет -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ================== Боковая панель ================== -->
        <Border Grid.Column="0" Background="{StaticResource PrimaryBrush}">
            <StackPanel>
                <!-- Название системы -->
                <TextBlock Text="БАНК «СТАНДАРТ»"
                           FontSize="18" FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,25,0,5"/>
                <TextBlock Text="Система учёта клиентов"
                           FontSize="11"
                           Foreground="{StaticResource LightTextBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,25"/>

                <!-- Меню -->
                <Button Content="📊 Рабочий стол" Style="{StaticResource MenuButton}"
                        Background="#2C5282" FontWeight="Bold"/>
                <Button x:Name="BtnClients" Content="👥 Клиенты" Style="{StaticResource MenuButton}"/>
                <Button Content="🔍 Поиск" Style="{StaticResource MenuButton}"/>
                <Button Content="📈 Отчёты" Style="{StaticResource MenuButton}"/>
                <Button Content="⚙️ Администрирование" Style="{StaticResource MenuButton}"/>
                <Button Content="👤 Настройки профиля" Style="{StaticResource MenuButton}"/>
            </StackPanel>
        </Border>

        <!-- ================== Рабочая область ================== -->
        <Grid Grid.Column="1" Background="{StaticResource BackgroundBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Верхняя панель с приветствием и быстрыми действиями -->
            <Border Grid.Row="0" Background="White" Padding="20" Margin="10,10,10,5"
                    CornerRadius="8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.08" Color="#1E3A5F"/>
                </Border.Effect>
                <Grid>
                    <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center">
                        <TextBlock Text="Добро пожаловать, Администратор!"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"/>
                        <TextBlock Text="Сегодня 12 мая 2026 г. | Четверг"
                                   FontSize="12" Foreground="{StaticResource LightTextBrush}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                        <Button Content="➕ Новый клиент" Style="{StaticResource ActionButton}" Margin="0,0,10,0"/>
                        <Button Content="🔎 Быстрый поиск" Style="{StaticResource ActionButton}" Margin="0,0,10,0"/>
                        <Button Content="📥 Импорт реестра" Style="{StaticResource ActionButton}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Центральная область с карточками дашборда -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <WrapPanel Margin="10,5,10,10" Orientation="Horizontal">
                    <!-- Карточка 1: Новые клиенты сегодня -->
                    <Border Style="{StaticResource DashboardCard}" Width="280" Height="140">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Новые клиенты сегодня"
                                       FontSize="13" Foreground="{StaticResource LightTextBrush}"/>
                            <TextBlock Text="0"
                                       FontSize="36" FontWeight="Bold"
                                       Foreground="{StaticResource PrimaryBrush}"
                                       Margin="0,8,0,0"/>
                            <TextBlock Text="Нет данных"
                                       FontSize="11" Foreground="{StaticResource LightTextBrush}" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Карточка 2: Ожидают верификации -->
                    <Border Style="{StaticResource DashboardCard}" Width="280" Height="140">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="На проверке"
                                       FontSize="13" Foreground="{StaticResource LightTextBrush}"/>
                            <TextBlock Text="0"
                                       FontSize="36" FontWeight="Bold"
                                       Foreground="#E67E22"
                                       Margin="0,8,0,0"/>
                            <TextBlock Text="Нет заявок"
                                       FontSize="11" Foreground="{StaticResource LightTextBrush}" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Карточка 3: Просроченные документы -->
                    <Border Style="{StaticResource DashboardCard}" Width="280" Height="140">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Просроченные документы"
                                       FontSize="13" Foreground="{StaticResource LightTextBrush}"/>
                            <TextBlock Text="0"
                                       FontSize="36" FontWeight="Bold"
                                       Foreground="#C0392B"
                                       Margin="0,8,0,0"/>
                            <TextBlock Text="Нет"
                                       FontSize="11" Foreground="{StaticResource LightTextBrush}" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Карточка 4: Всего клиентов -->
                    <Border Style="{StaticResource DashboardCard}" Width="280" Height="140">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Всего клиентов"
                                       FontSize="13" Foreground="{StaticResource LightTextBrush}"/>
                            <TextBlock Text="0"
                                       FontSize="36" FontWeight="Bold"
                                       Foreground="{StaticResource PrimaryBrush}"
                                       Margin="0,8,0,0"/>
                            <TextBlock Text="Активных: 0"
                                       FontSize="11" Foreground="{StaticResource LightTextBrush}" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>
                </WrapPanel>
            </ScrollViewer>

            <!-- Нижняя строка состояния -->
            <Border Grid.Row="2" Background="White" Padding="15" Margin="10,0,10,10"
                    CornerRadius="4" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <Grid>
                    <TextBlock HorizontalAlignment="Left" FontSize="12"
                               Foreground="{StaticResource LightTextBrush}"
                               Text="Пользователь: admin | Роль: Администратор"/>
                    <TextBlock HorizontalAlignment="Right" FontSize="12"
                               Foreground="{StaticResource LightTextBrush}"
                               Text="Версия 1.0 | © 2025 Банк «Стандарт»"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>