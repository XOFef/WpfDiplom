<Window x:Class="WpfDiplom.AddEditUserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Пользователь" Height="520" Width="550"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F7FA">

    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#1E3A5F"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#D4AF37"/>
        <SolidColorBrush x:Key="BackgroundBrush" Color="#F5F7FA"/>
        <SolidColorBrush x:Key="TextBrush" Color="#2C3E50"/>
        <SolidColorBrush x:Key="LightTextBrush" Color="#7F8C8D"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#E0E6ED"/>
        <SolidColorBrush x:Key="ButtonBrush" Color="#2C5282"/>
        <SolidColorBrush x:Key="ButtonHoverBrush" Color="#3A6EA5"/>

        <Style TargetType="TextBox" x:Key="InputField">
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="ComboBox" x:Key="InputCombo">
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="FieldLabel">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource LightTextBrush}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style TargetType="Button" x:Key="DialogButton">
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource ButtonBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="Margin" Value="8,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource ButtonHoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <Border Grid.Row="0" CornerRadius="6,6,0,0" Height="56">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#1E3A5F" Offset="0"/>
                    <GradientStop Color="#2C5282" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid Margin="20,0">
                <TextBlock x:Name="TitleText" Text="👤 Новый пользователь" 
                           Foreground="White" FontSize="18" FontWeight="Bold"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Основная область -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="20,15,20,10">
            <StackPanel>
                <TextBlock Text="Логин *" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="TxtLogin" Style="{StaticResource InputField}" Margin="0,0,0,15"/>

                <TextBlock Text="Полное имя *" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="TxtFullName" Style="{StaticResource InputField}" Margin="0,0,0,15"/>

                <TextBlock Text="Должность" Style="{StaticResource FieldLabel}"/>
                <TextBox x:Name="TxtPosition" Style="{StaticResource InputField}" Margin="0,0,0,15"/>

                <TextBlock Text="Роль *" Style="{StaticResource FieldLabel}"/>
                <ComboBox x:Name="CmbRole" Style="{StaticResource InputCombo}" Margin="0,0,0,15"
                          DisplayMemberPath="Name" SelectedValuePath="Id"/>

                <TextBlock Text="Отделение *" Style="{StaticResource FieldLabel}"/>
                <ComboBox x:Name="CmbBranch" Style="{StaticResource InputCombo}" Margin="0,0,0,15"
                          DisplayMemberPath="Name" SelectedValuePath="Id"/>

                <CheckBox x:Name="ChkIsActive" Content="✅ Учётная запись активна" 
                          FontSize="14" Foreground="{StaticResource TextBrush}"
                          Margin="0,10,0,0"/>

                <TextBlock Text="* — обязательные поля" FontSize="11" 
                           Foreground="{StaticResource LightTextBrush}" 
                           Margin="0,15,0,0" HorizontalAlignment="Right"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Нижняя панель -->
        <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0" Padding="15,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Сохранить" Style="{StaticResource DialogButton}"
                        Click="BtnSave_Click"/>
                <Button Content="Отмена" Style="{StaticResource DialogButton}"
                        Background="#95A5A6" Click="BtnCancel_Click">
                    <Button.Resources>
                        <SolidColorBrush x:Key="Background" Color="#95A5A6"/>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>