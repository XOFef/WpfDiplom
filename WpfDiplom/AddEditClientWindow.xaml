<Window x:Class="WpfDiplom.AddEditClientWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Новый клиент | Банк «Стандарт»" Height="680" Width="850"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="#F5F7FA">
    <Window.Resources>
        <!-- Цветовая гамма -->
        <SolidColorBrush x:Key="PrimaryBrush" Color="#1E3A5F"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#D4AF37"/>
        <SolidColorBrush x:Key="BackgroundBrush" Color="#F5F7FA"/>
        <SolidColorBrush x:Key="TextBrush" Color="#2C3E50"/>
        <SolidColorBrush x:Key="LightTextBrush" Color="#7F8C8D"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#E0E6ED"/>
        <SolidColorBrush x:Key="ButtonBrush" Color="#2C5282"/>
        <SolidColorBrush x:Key="ButtonHoverBrush" Color="#3A6EA5"/>

        <!-- Стиль кнопки -->
        <Style TargetType="Button" x:Key="SimpleButton">
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource ButtonBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Margin" Value="5,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource ButtonHoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль секции-карточки -->
        <Style TargetType="Border" x:Key="SectionCard">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="6" ShadowDepth="2" Opacity="0.08" Color="#1E3A5F"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для заголовка секции -->
        <Style TargetType="TextBlock" x:Key="SectionHeader">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <!-- Стиль поля ввода -->
        <Style TargetType="TextBox" x:Key="InputField">
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- Стиль выпадающего списка -->
        <Style TargetType="ComboBox" x:Key="InputCombo">
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <!-- Стиль для подписи поля -->
        <Style TargetType="TextBlock" x:Key="FieldLabel">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource LightTextBrush}"/>
            <Setter Property="Margin" Value="0,8,0,4"/>
        </Style>

        <!-- Стиль для DatePicker – без опасных свойств -->
        <Style TargetType="DatePicker" x:Key="InputDate">
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель с градиентом -->
        <Border Grid.Row="0" CornerRadius="6" Margin="0,0,0,10" Height="56">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#1E3A5F" Offset="0"/>
                    <GradientStop Color="#2C5282" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid Margin="16,0">
                <TextBlock Text="Новый клиент" 
                           Foreground="White" FontSize="18" FontWeight="Bold"
                           VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Сохранить" Style="{StaticResource SimpleButton}"
                            x:Name="BtnSave" Click="BtnSave_Click"/>
                    <Button Content="Сохранить и загрузить документы" Style="{StaticResource SimpleButton}"
                            x:Name="BtnSaveAndDocs" Click="BtnSaveAndDocs_Click"/>
                    <Button Content="Отмена" Style="{StaticResource SimpleButton}"
                            Background="#95A5A6" Click="BtnCancel_Click">
                        <Button.Resources>
                            <SolidColorBrush x:Key="Background" Color="#95A5A6"/>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Основная область с прокруткой -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Тип клиента -->
                <Border Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="📌 Тип клиента" Style="{StaticResource SectionHeader}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <RadioButton x:Name="RbIndividual" Content="Физическое лицо" GroupName="ClientType"
                                         IsChecked="True" FontSize="14" Margin="0,0,20,0"
                                         Checked="ClientTypeChanged"
                                         Foreground="{StaticResource TextBrush}"/>
                            <RadioButton x:Name="RbLegal" Content="Юридическое лицо" GroupName="ClientType"
                                         FontSize="14" Margin="0,0,20,0"
                                         Checked="ClientTypeChanged"
                                         Foreground="{StaticResource TextBrush}"/>
                            <RadioButton x:Name="RbEntrepreneur" Content="Индивидуальный предприниматель"
                                         GroupName="ClientType" FontSize="14"
                                         Checked="ClientTypeChanged"
                                         Foreground="{StaticResource TextBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Физическое лицо -->
                <Border x:Name="PanelIndividual" Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="👤 Данные физического лица" Style="{StaticResource SectionHeader}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="Фамилия *" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="LastName" Style="{StaticResource InputField}" Margin="0,0,0,12"/>
                                <TextBlock Text="Имя *" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="FirstName" Style="{StaticResource InputField}" Margin="0,0,0,12"/>
                                <TextBlock Text="Отчество" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="MiddleName" Style="{StaticResource InputField}" Margin="0,0,0,12"/>
                                <TextBlock Text="Дата рождения *" Style="{StaticResource FieldLabel}"/>
                                <DatePicker x:Name="BirthDate" Style="{StaticResource InputDate}" Margin="0,0,0,12"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Место рождения" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="BirthPlace" Style="{StaticResource InputField}" Margin="0,0,0,12"/>
                                <TextBlock Text="Гражданство" Style="{StaticResource FieldLabel}"/>
                                <ComboBox x:Name="Citizenship" Style="{StaticResource InputCombo}" Margin="0,0,0,12"
                                          SelectedIndex="0">
                                    <ComboBoxItem Content="Российская Федерация"/>
                                    <ComboBoxItem Content="Другое"/>
                                </ComboBox>
                                <TextBlock Text="Пол" Style="{StaticResource FieldLabel}"/>
                                <ComboBox x:Name="Gender" Style="{StaticResource InputCombo}" Margin="0,0,0,12"
                                          SelectedIndex="0">
                                    <ComboBoxItem Content="Мужской"/>
                                    <ComboBoxItem Content="Женский"/>
                                </ComboBox>
                                <TextBlock Text="Телефон *" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="Phone" Style="{StaticResource InputField}" Margin="0,0,0,12"/>
                                <TextBlock Text="Email" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="Email" Style="{StaticResource InputField}" Margin="0,0,0,12"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Юридическое лицо -->
                <Border x:Name="PanelLegal" Style="{StaticResource SectionCard}" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="🏢 Данные юридического лица" Style="{StaticResource SectionHeader}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="Полное наименование *" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="FullNameLegal" Style="{StaticResource InputField}" Margin="0,0,0,12"/>
                                <TextBlock Text="Краткое наименование" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="ShortName" Style="{StaticResource InputField}" Margin="0,0,0,12"/>
                                <TextBlock Text="ОПФ *" Style="{StaticResource FieldLabel}"/>
                                <ComboBox x:Name="OrgForm" Style="{StaticResource InputCombo}" Margin="0,0,0,12"
                                          SelectedIndex="0">
                                    <ComboBoxItem Content="ООО"/>
                                    <ComboBoxItem Content="АО"/>
                                    <ComboBoxItem Content="ПАО"/>
                                </ComboBox>
                                <TextBlock Text="ОГРН *" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="Ogrn" Style="{StaticResource InputField}" Margin="0,0,0,12"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="ИНН *" Style="{StaticResource FieldLabel}"/>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="InnLegal" Style="{StaticResource InputField}"
                                             Margin="0,0,8,0"/>
                                    <Button Grid.Column="1" Content="Проверить на дубли" Style="{StaticResource SimpleButton}"
                                            Height="32" FontSize="13" Padding="10,0"
                                            Click="CheckDuplicate_Click"/>
                                </Grid>
                                <TextBlock Text="КПП" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="Kpp" Style="{StaticResource InputField}" Margin="0,0,0,12"/>
                                <TextBlock Text="Дата регистрации" Style="{StaticResource FieldLabel}"/>
                                <DatePicker x:Name="RegDateLegal" Style="{StaticResource InputDate}" Margin="0,0,0,12"/>
                                <TextBlock Text="Юридический адрес *" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="LegalAddress" Style="{StaticResource InputField}" Margin="0,0,0,12"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ИП -->
                <Border x:Name="PanelEntrepreneur" Style="{StaticResource SectionCard}" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="📊 Данные индивидуального предпринимателя" Style="{StaticResource SectionHeader}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="Фамилия *" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="LastNameIP" Style="{StaticResource InputField}" Margin="0,0,0,12"/>
                                <TextBlock Text="Имя *" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="FirstNameIP" Style="{StaticResource InputField}" Margin="0,0,0,12"/>
                                <TextBlock Text="Отчество" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="MiddleNameIP" Style="{StaticResource InputField}" Margin="0,0,0,12"/>
                                <TextBlock Text="Дата рождения *" Style="{StaticResource FieldLabel}"/>
                                <DatePicker x:Name="BirthDateIP" Style="{StaticResource InputDate}" Margin="0,0,0,12"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="ИНН *" Style="{StaticResource FieldLabel}"/>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="InnIP" Style="{StaticResource InputField}"
                                             Margin="0,0,8,0"/>
                                    <Button Grid.Column="1" Content="Проверить на дубли" Style="{StaticResource SimpleButton}"
                                            Height="32" FontSize="13" Padding="10,0"
                                            Click="CheckDuplicate_Click"/>
                                </Grid>
                                <TextBlock Text="ОГРНИП *" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="Ogrnip" Style="{StaticResource InputField}" Margin="0,0,0,12"/>
                                <TextBlock Text="Телефон *" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="PhoneIP" Style="{StaticResource InputField}" Margin="0,0,0,12"/>
                                <TextBlock Text="Email" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="EmailIP" Style="{StaticResource InputField}" Margin="0,0,0,12"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Паспортные данные (для ФЛ и ИП) -->
                <Border x:Name="PanelPassport" Style="{StaticResource SectionCard}">
                    <StackPanel>
                        <TextBlock Text="🛂 Паспортные данные" Style="{StaticResource SectionHeader}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="Тип документа" Style="{StaticResource FieldLabel}"/>
                                <ComboBox x:Name="DocType" Style="{StaticResource InputCombo}" Margin="0,0,0,12"
                                          SelectedIndex="0">
                                    <ComboBoxItem Content="Паспорт РФ"/>
                                    <ComboBoxItem Content="Загранпаспорт"/>
                                </ComboBox>
                                <TextBlock Text="Серия *" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="DocSeries" Style="{StaticResource InputField}" Margin="0,0,0,12"/>
                                <TextBlock Text="Номер *" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="DocNumber" Style="{StaticResource InputField}" Margin="0,0,0,12"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Дата выдачи *" Style="{StaticResource FieldLabel}"/>
                                <DatePicker x:Name="DocIssueDate" Style="{StaticResource InputDate}" Margin="0,0,0,12"/>
                                <TextBlock Text="Кем выдан *" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="DocIssuer" Style="{StaticResource InputField}" Margin="0,0,0,12"/>
                                <TextBlock Text="Код подразделения" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="DocCode" Style="{StaticResource InputField}" Margin="0,0,0,12"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>