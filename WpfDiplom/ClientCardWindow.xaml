<Window x:Class="WpfDiplom.ClientCardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Карточка клиента | Банк «Стандарт»" Height="750" Width="950"
        WindowStartupLocation="CenterScreen"
        MinHeight="650" MinWidth="800">
    <Window.Resources>
        <!-- Основные цвета -->
        <SolidColorBrush x:Key="PrimaryBrush" Color="#1E3A5F"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#D4AF37"/>
        <SolidColorBrush x:Key="BackgroundBrush" Color="#F5F7FA"/>
        <SolidColorBrush x:Key="TextBrush" Color="#2C3E50"/>
        <SolidColorBrush x:Key="LightTextBrush" Color="#7F8C8D"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#E0E6ED"/>
        <SolidColorBrush x:Key="ButtonBrush" Color="#2C5282"/>
        <SolidColorBrush x:Key="ButtonHoverBrush" Color="#3A6EA5"/>

        <!-- Простая плоская кнопка -->
        <Style TargetType="Button" x:Key="SimpleButton">
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource ButtonBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Margin" Value="3,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource ButtonHoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для секций -->
        <Style TargetType="Border" x:Key="SectionBorder">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- Заголовок секции -->
        <Style TargetType="TextBlock" x:Key="SectionHeader">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <!-- Простой DataGrid -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="ColumnHeaderHeight" Value="30"/>
            <Setter Property="RowHeight" Value="28"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <Border Grid.Row="0" Background="White" Padding="12" Margin="10,10,10,5"
                CornerRadius="4" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <Grid>
                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center">
                    <TextBlock Text="Иванов Иван Иванович" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}"/>
                    <TextBlock Text="ID: 1423 | Физ. лицо | Активен" FontSize="12"
                               Foreground="{StaticResource LightTextBrush}" Margin="0,2,0,0"/>
                </StackPanel>
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <Button Content="✏ Редактировать" Style="{StaticResource SimpleButton}"/>
                    <Button Content="🗑 Удалить" Style="{StaticResource SimpleButton}" Background="#C0392B">
                        <Button.Resources>
                            <SolidColorBrush x:Key="Background" Color="#C0392B"/>
                        </Button.Resources>
                    </Button>
                    <Button Content="✖ Закрыть" Style="{StaticResource SimpleButton}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Основная область с прокруткой -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="10,0,10,10">
            <StackPanel>
                <!-- 1. Общая информация -->
                <Border Style="{StaticResource SectionBorder}">
                    <StackPanel>
                        <TextBlock Text="📋 Основная информация" Style="{StaticResource SectionHeader}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="Фамилия:" Foreground="{StaticResource LightTextBrush}" FontSize="13"/>
                                <TextBlock Text="Иванов" FontSize="14" Margin="0,2,0,8"/>
                                <TextBlock Text="Имя:" Foreground="{StaticResource LightTextBrush}" FontSize="13"/>
                                <TextBlock Text="Иван" FontSize="14" Margin="0,2,0,8"/>
                                <TextBlock Text="Отчество:" Foreground="{StaticResource LightTextBrush}" FontSize="13"/>
                                <TextBlock Text="Иванович" FontSize="14" Margin="0,2,0,8"/>
                                <TextBlock Text="Дата рождения:" Foreground="{StaticResource LightTextBrush}" FontSize="13"/>
                                <TextBlock Text="15.03.1985" FontSize="14" Margin="0,2,0,8"/>
                                <TextBlock Text="Место рождения:" Foreground="{StaticResource LightTextBrush}" FontSize="13"/>
                                <TextBlock Text="г. Москва" FontSize="14" Margin="0,2,0,8"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Гражданство:" Foreground="{StaticResource LightTextBrush}" FontSize="13"/>
                                <TextBlock Text="Российская Федерация" FontSize="14" Margin="0,2,0,8"/>
                                <TextBlock Text="Пол:" Foreground="{StaticResource LightTextBrush}" FontSize="13"/>
                                <TextBlock Text="Мужской" FontSize="14" Margin="0,2,0,8"/>
                                <TextBlock Text="Телефон:" Foreground="{StaticResource LightTextBrush}" FontSize="13"/>
                                <TextBlock Text="+7 (926) 123-45-67" FontSize="14" Margin="0,2,0,8"/>
                                <TextBlock Text="Email:" Foreground="{StaticResource LightTextBrush}" FontSize="13"/>
                                <TextBlock Text="ivanov@example.com" FontSize="14" Margin="0,2,0,8"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 2. Паспортные данные -->
                <Border Style="{StaticResource SectionBorder}">
                    <StackPanel>
                        <TextBlock Text="🛂 Паспортные данные" Style="{StaticResource SectionHeader}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="Тип документа:" Foreground="{StaticResource LightTextBrush}" FontSize="13"/>
                                <TextBlock Text="Паспорт РФ" FontSize="14" Margin="0,2,0,8"/>
                                <TextBlock Text="Серия:" Foreground="{StaticResource LightTextBrush}" FontSize="13"/>
                                <TextBlock Text="45 12" FontSize="14" Margin="0,2,0,8"/>
                                <TextBlock Text="Номер:" Foreground="{StaticResource LightTextBrush}" FontSize="13"/>
                                <TextBlock Text="345678" FontSize="14" Margin="0,2,0,8"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Дата выдачи:" Foreground="{StaticResource LightTextBrush}" FontSize="13"/>
                                <TextBlock Text="20.05.2010" FontSize="14" Margin="0,2,0,8"/>
                                <TextBlock Text="Кем выдан:" Foreground="{StaticResource LightTextBrush}" FontSize="13"/>
                                <TextBlock Text="ОВД «Ленинский» г. Москвы" FontSize="14" Margin="0,2,0,8"/>
                                <TextBlock Text="Код подразделения:" Foreground="{StaticResource LightTextBrush}" FontSize="13"/>
                                <TextBlock Text="123-456" FontSize="14" Margin="0,2,0,8"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 3. Документы -->
                <Border Style="{StaticResource SectionBorder}">
                    <StackPanel>
                        <TextBlock Text="📁 Документы" Style="{StaticResource SectionHeader}"/>
                        <Button Content="📤 Загрузить файл" Style="{StaticResource SimpleButton}"
                                HorizontalAlignment="Left" Margin="0,0,0,8"/>
                        <DataGrid IsReadOnly="True" AutoGenerateColumns="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Наименование" Width="*" Binding="{Binding Name}"/>
                                <DataGridTextColumn Header="Тип" Width="130" Binding="{Binding Type}"/>
                                <DataGridTextColumn Header="Дата загрузки" Width="110" Binding="{Binding Date}"/>
                                <DataGridTextColumn Header="Кто загрузил" Width="140" Binding="{Binding User}"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <!-- 4. Счета и продукты -->
                <Border Style="{StaticResource SectionBorder}">
                    <StackPanel>
                        <TextBlock Text="💰 Счета и продукты" Style="{StaticResource SectionHeader}"/>
                        <Button Content="➕ Открыть новый счёт" Style="{StaticResource SimpleButton}"
                                HorizontalAlignment="Left" Margin="0,0,0,8"/>
                        <DataGrid IsReadOnly="True" AutoGenerateColumns="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Номер счёта" Width="*" Binding="{Binding AccountNum}"/>
                                <DataGridTextColumn Header="Тип" Width="120" Binding="{Binding AccountType}"/>
                                <DataGridTextColumn Header="Валюта" Width="70" Binding="{Binding Currency}"/>
                                <DataGridTextColumn Header="Остаток" Width="100" Binding="{Binding Balance}"/>
                                <DataGridTextColumn Header="Дата открытия" Width="110" Binding="{Binding OpenDate}"/>
                                <DataGridTextColumn Header="Статус" Width="90" Binding="{Binding Status}"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <!-- 5. История взаимодействий -->
                <Border Style="{StaticResource SectionBorder}">
                    <StackPanel>
                        <TextBlock Text="🕐 История взаимодействий" Style="{StaticResource SectionHeader}"/>
                        <TextBox Height="50" Margin="0,0,0,6" TextWrapping="Wrap" AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 BorderBrush="{StaticResource BorderBrush}" FontSize="13" Padding="6"/>
                        <Button Content="Добавить заметку" Style="{StaticResource SimpleButton}"
                                HorizontalAlignment="Right" Margin="0,0,0,6"/>
                        <DataGrid IsReadOnly="True" AutoGenerateColumns="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Дата" Width="110" Binding="{Binding Date}"/>
                                <DataGridTextColumn Header="Тип" Width="110" Binding="{Binding Type}"/>
                                <DataGridTextColumn Header="Содержание" Width="*" Binding="{Binding Content}"/>
                                <DataGridTextColumn Header="Автор" Width="130" Binding="{Binding Author}"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <!-- 6. Дополнительная информация -->
                <Border Style="{StaticResource SectionBorder}">
                    <StackPanel>
                        <TextBlock Text="📎 Дополнительная информация" Style="{StaticResource SectionHeader}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="Статус резидентства:" Foreground="{StaticResource LightTextBrush}" FontSize="13"/>
                                <TextBlock Text="Резидент" FontSize="14" Margin="0,2,0,8"/>
                                <TextBlock Text="VIP-признак:" Foreground="{StaticResource LightTextBrush}" FontSize="13"/>
                                <TextBlock Text="Нет" FontSize="14" Margin="0,2,0,8"/>
                                <TextBlock Text="Источник привлечения:" Foreground="{StaticResource LightTextBrush}" FontSize="13"/>
                                <TextBlock Text="Рекомендация" FontSize="14" Margin="0,2,0,8"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Персональный менеджер:" Foreground="{StaticResource LightTextBrush}" FontSize="13"/>
                                <TextBlock Text="Петрова Анна Викторовна" FontSize="14" Margin="0,2,0,8"/>
                                <TextBlock Text="Дата регистрации:" Foreground="{StaticResource LightTextBrush}" FontSize="13"/>
                                <TextBlock Text="10.01.2020" FontSize="14" Margin="0,2,0,8"/>
                                <TextBlock Text="Статус клиента:" Foreground="{StaticResource LightTextBrush}" FontSize="13"/>
                                <TextBlock Text="Активен" FontSize="14" Margin="0,2,0,8" Foreground="#27AE60"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>