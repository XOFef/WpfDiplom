<Window x:Class="WpfDiplom.ProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройки профиля | Банк «Стандарт»" Height="450" Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F0F2F5">
    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#1E3A5F"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#D0D5DD"/>
        <SolidColorBrush x:Key="ButtonBrush" Color="#2C5282"/>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}"
                CornerRadius="4" Padding="12" Margin="0,0,0,10">
            <Grid>
                <TextBlock Text="Настройки профиля" Foreground="White"
                           FontSize="17" FontWeight="Bold" VerticalAlignment="Center"/>
                <Button Content="Закрыть" Width="80" Height="28"
                        Background="#95A5A6" Foreground="White" BorderThickness="0"
                        FontSize="13" HorizontalAlignment="Right"
                        Click="BtnClose_Click"/>
            </Grid>
        </Border>

        <!-- Секции -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Смена пароля -->
                <Border Background="White" BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="4" Padding="15" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="🔒 Смена пароля" FontWeight="Bold" FontSize="14"
                                   Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,10"/>
                        <TextBlock Text="Старый пароль" FontSize="12" Foreground="#555" Margin="0,0,0,3"/>
                        <PasswordBox x:Name="OldPassword" Height="30" Margin="0,0,0,10"/>
                        <TextBlock Text="Новый пароль" FontSize="12" Foreground="#555" Margin="0,0,0,3"/>
                        <PasswordBox x:Name="NewPassword" Height="30" Margin="0,0,0,10"/>
                        <TextBlock Text="Подтверждение пароля" FontSize="12" Foreground="#555" Margin="0,0,0,3"/>
                        <PasswordBox x:Name="ConfirmPassword" Height="30" Margin="0,0,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Контактные данные -->
                <Border Background="White" BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="4" Padding="15" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="📞 Контактные данные" FontWeight="Bold" FontSize="14"
                                   Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,10"/>
                        <TextBlock Text="Телефон" FontSize="12" Foreground="#555" Margin="0,0,0,3"/>
                        <TextBox x:Name="Phone" Height="30" Margin="0,0,0,10"/>
                        <TextBlock Text="Email" FontSize="12" Foreground="#555" Margin="0,0,0,3"/>
                        <TextBox x:Name="Email" Height="30" Margin="0,0,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Кнопки действий -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Сохранить" Width="100" Height="30"
                            Background="{StaticResource ButtonBrush}" Foreground="White"
                            BorderThickness="0" FontSize="13" Margin="0,0,10,0"
                            Click="BtnSave_Click"/>
                    <Button Content="Отмена" Width="80" Height="30"
                            Background="#95A5A6" Foreground="White" BorderThickness="0"
                            FontSize="13" Click="BtnClose_Click"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>